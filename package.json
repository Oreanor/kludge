{
  "name": "kludge-code",
  "displayName": "Kludge Code",
  "description": "Kludge Code AI assistant for VS Code",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "kludge.helloWorld",        "title": "Hello World" },
      { "command": "kludge.testStream",        "title": "Kludge Code: Test Stream" },
      { "command": "kludge.openChat",          "title": "Kludge Code: Open Chat" },
      { "command": "kludge.sendMessage",       "title": "Kludge Code: Send Message" },
      { "command": "kludge.openPreview",       "title": "Kludge Code: Open Preview",   "icon": "$(browser)" },
      { "command": "kludge.reloadPreview",     "title": "Kludge Code: Reload Preview", "icon": "$(refresh)" },
      { "command": "kludge.pickElement",       "title": "Kludge Code: Pick Element",   "icon": "$(inspect)" },
      { "command": "kludge.setAnthropicKey",   "title": "Kludge Code: Set Anthropic API Key" },
      { "command": "kludge.clearAnthropicKey", "title": "Kludge Code: Clear Anthropic API Key" }
    ],
   "viewsContainers": {
      "activitybar": [{
        "id": "kludge-sidebar",
        "title": "Kludge Code",
        "icon": "$(flame)"
      }]
    },
    "views": {
      "kludge-sidebar": [{
        "type": "webview",
        "id": "kludge.chatView",
        "name": "Chat"
      }]
    }
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "node esbuild.config.mjs",
    "build:webview": "vite build",
    "watch": "npm run build:ext -- --watch",
    "compile": "npm run build:ext",
    "lint": "eslint src webview/src",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test",
    "vscode:prepublish": "npm run build"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.116.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@google/generative-ai": "^0.24.1",
    "dotenv": "^17.4.2",
    "ollama": "^0.6.3"
  }
}